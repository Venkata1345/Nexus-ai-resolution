# ---------------------------------------------------------------
# Nexus environment template.
# Copy to `.env` and fill in real values. The `.env` file itself
# is gitignored — never commit real secrets.
# ---------------------------------------------------------------

# --- REQUIRED ---
# Google Generative AI API key. Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- OPTIONAL OVERRIDES ---
# Any Settings field in src/config.py can be overridden here. Examples:
# MLFLOW_TRACKING_URI=http://localhost:5000
# GEMINI_MODEL=gemini-1.5-flash
# LLM_TEMPERATURE=0.1
