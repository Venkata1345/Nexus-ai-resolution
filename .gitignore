# ---------- Secrets (NEVER commit) ----------
.env
.env.*
!.env.example
*.pem
*.key
credentials.json

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
build/
dist/
.eggs/

# ---------- Virtual environments ----------
.venv/
venv/
env/
ENV/

# ---------- IDE / Editor (machine-specific) ----------
.vscode/
.idea/
.claude/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------- Type checkers & linters ----------
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# ---------- Testing ----------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# ---------- ML artifacts (tracked by MLflow/DVC, not git) ----------
mlruns/
mlflow.db
mlflow.db-journal
models/*.pkl
models/*.joblib
models/*.ubj
# Processed data is a derived artifact of the raw CSV + split params;
# DVC will track it, never git.
data/processed/
# RAG knowledge base — regenerated by src.agents.kb_build
data/kb/
# Deployment bundle — regenerated by src.router.bundle
bundle/

# ---------- DVC ----------
# NOTE: .dvc/ folder IS committed (config, .gitignore, etc.)
#       .dvc/cache/ is already ignored by DVC itself
#       *.dvc metadata files ARE committed (they're pointers to data)

# ---------- Jupyter ----------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------- Logs ----------
*.log
logs/

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini
